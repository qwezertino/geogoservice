# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=geouser
DB_PASSWORD=changeme
DB_NAME=geodb

# Host port exposed to your machine (change freely without breaking anything)
HOST_PORT_DB=5432

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=ndvi-tiles

# Host ports exposed to your machine
HOST_PORT_MINIO=9000          # S3 API
HOST_PORT_MINIO_CONSOLE=9001  # Web UI (http://localhost:9001)

# ── HTTP / Nginx ───────────────────────────────────────────────────────────────
# Host port for the public-facing Nginx load balancer
HOST_PORT_HTTP=7001

# ── STAC provider ─────────────────────────────────────────────────────────────
# Which satellite data provider to use first. If it fails, the service
# automatically falls back to the next registered provider.
# Options: planetary-computer (default) | earth-search
STAC_PROVIDER=planetary-computer

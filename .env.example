# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=geouser
DB_PASSWORD=geopassword
DB_NAME=geodb

# Host port exposed to your machine (change freely without breaking anything)
HOST_PORT_DB=7432

# ── MinIO client credentials ─────────────────────────────────────────────────
# Must match MINIO_ROOT_USER / MINIO_ROOT_PASSWORD in the minio-infra project.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=geopassword
MINIO_BUCKET=ndvi-tiles

# MinIO itself is in the separate minio-infra project (../minio-infra).
# MINIO_ENDPOINT is set in docker-compose.yml and resolved via the shared-infra network.

# ── HTTP / Nginx ───────────────────────────────────────────────────────────────
# Host port for the public-facing Nginx load balancer
HOST_PORT_HTTP=7001

# ── GDAL ─────────────────────────────────────────────────────────────────────
GDAL_HTTP_UNSAFESSL=YES
CPL_VSIL_CURL_ALLOWED_EXTENSIONS=.tif,.tiff,.jp2
GDAL_HTTP_MAX_RETRY=3
GDAL_HTTP_RETRY_DELAY=1
GDAL_HTTP_TIMEOUT=5
# Merge adjacent HTTP range requests into one — reduces JP2 cold-open from
# 30-50 requests down to 5-10. Critical for CDSE /vsis3/ JP2 reliability.
GDAL_HTTP_MERGE_CONSECUTIVE_RANGES=YES
# Fetch 1 MB per range request instead of the default 16 KB — fewer round
# trips to parse JP2 box structure and codestream headers.
CPL_VSIL_CURL_CHUNK_SIZE=1048576
GDAL_DISABLE_READDIR_ON_OPEN=EMPTY_DIR
CPL_VSIL_USE_TEMP_FILE_FOR_RANDOM_WRITE=NO
VSI_CACHE=TRUE
VSI_CACHE_SIZE=134217728

# ── STAC ──────────────────────────────────────────────────────────────────────
STAC_PROVIDER=planetary-computer
STAC_SEARCH_WINDOW_DAYS=5
STAC_MAX_CLOUD_COVER=20
# ── CDSE (Copernicus Data Space Ecosystem) ────────────────────────────────────
# Register a free account at https://dataspace.copernicus.eu, then generate
# long-lived S3 credentials at https://eodata-s3keysmanager.dataspace.copernicus.eu/
CDSE_S3_ACCESS_KEY=
CDSE_S3_SECRET_KEY=